# Allowlisting gitignore
# Ignore everything
*

# But not these files...
!/.github/**/*
!/.gitignore
!/.tool-versions

!README.md
!LICENSE

# Latest-version feed read by `cru`'s in-process update check
# (CruGlobal/cru-cli internal/versioncheck); updated by cru-cli's release
# pipeline.
!/version.json

!bin/install
!bin/list-all

# ...even if they are in subdirectories
!*/
